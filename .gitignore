# dependencies
node_modules/

# build output
dist/
build/
*.tsbuildinfo

# runtime data cache (L2 on-disk ingest cache) — any package (anchored patterns
# with a slash only match the repo root, so glob from any depth)
**/data/cache/

# env / secrets
.env
.env.*
!.env.example

# test / coverage
coverage/

# brainstorming visual-companion mockups (transient, per-session)
.superpowers/

# misc
.DS_Store
*.log

# stray screenshots pasted at the repo root (real assets live in packages/web/public)
/*.png
