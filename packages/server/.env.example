# Copy to `.env` and fill in. The server reads these only at the edge (index.ts).
# `pnpm dev` loads `.env` via `tsx watch --env-file-if-exists=.env`.

# Champions sheet as CSV EXPORT (NOT the /edit URL):
#   https://docs.google.com/spreadsheets/d/<SHEET_ID>/export?format=csv&gid=<GID>
SHEET_CSV_URL=

# PokeAPI base for sprites (default works; repoint to the pinned fan-mega instance if needed).
POKEAPI_BASE_URL=https://pokeapi.co/api/v2

# Disk cache path for the species->sprite map (relative to the server cwd).
SPRITE_CACHE_PATH=data/cache/sprites.json
